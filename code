void setDeck(Card* deck) {
	string faces[]= {"Ace","Two","Three","Four","Five","Six","Seven","Eight",
	                 "Nine","Ten","Jack","Queen","King"      // card faces
	                };

    string suits[]={"\u2663", "\u2665", "\u2666", "\u2660"}; // suits ♣ ♥ ♦ ♠
	int l=0;

	for (int i=0; i<4; i++) {
		for (int j=0; j<13; j++) {
			deck[l].face=faces[j];
			deck[l].suit=suits[i];

			if(j==0) {      // makes ace valued high 
				deck[l].value=14;
			} else {        // rest of standard card values 
				deck[l].value=j+1;
			}

			l++;
		}
	}
}

void printCard(const Card& c) {
    string f=c.face;
    
    // abbriviates faces for card printing
    if (f=="Ace") f="A";
    else if (f=="King") f="K";
    else if (f=="Queen") f="Q";
    else if (f=="Jack") f="J";
    else if (f=="Ten") f="10";
    else f=to_string(c.value);    // values 2-9
    
    // top
     cout<<"┌─────────┐"<<endl;

    // top left
    cout<<"│"<<f;
    if (f.length()==1) cout<<"        │"<<endl;
    else cout<<"       │"<<endl;

    // middle (centered suit)
    cout<<"│    "<<c.suit<<"    │"<<endl;
    
    // bottom right
    cout<<"│";
    if (f.length()==1) cout<<"        "<<f<<"│"<<endl;
    else cout<<"       "<<f<<"│"<<endl;

    cout<<"└─────────┘"<<endl;
	// ELSE accounts for "10"
}

void shuffleDeck(Card* deck, int size) {
	// randomizes card placements
	for(int x=0; x<size; x++) {
		int r=rand()%size;
		Card temp=deck[x];
		deck[x]=deck[r];
		deck[r]=temp;
	}
}

void deal(Player &p, Card* deck, int &top) {
	// give player 6 card hand
	p.handSize=6;

	for(int i=0; i<6; i++) {
		p.hand[i]=deck[top++];
	}
}

void startGame(Player &p1, Player &p2, Player &p3, Card* deck, int &top) {
    // shuffle deck and deal out to p1, p2, & p3
    shuffleDeck(deck, 52);
    
    deal(p1, deck, top);
    deal(p2, deck, top);
    deal(p3, deck, top);
}

int findLowest(Player &p) {
    // find lowest value card in hand for verification
    int idx=0;
    for (int i=1; i<p.handSize; i++){
        if (p.hand[i].value<p.hand[idx].value)
        idx=i;
    }   
    return idx;
}

int findLegal(Player &p, int lastValue) {
    // validates cards that are >= greatest value played
    for (int i=0; i<p.handSize; i++){
        if (p.hand[i].value>=lastValue)
        return i;
    }
    return -1;
}

void removeCard(Player &p, int idx) {
    // removes card when played
    for (int i=idx; i<p.handSize-1; i++){
        p.hand[i]=p.hand[i+1];
    }
    p.handSize--;
}

int playRound(Player &p1, Player &p2, Player &p3, int startPlayer) {
bool finalRound=(p1.handSize==1&&p2.handSize==1&&p3.handSize==1);
    
    Play pool[3];
    int poolSize=0;
    
    int lastValue=0;
    
    int order[3]={0, 1, 2};
    
    int winner=startPlayer;
    int highest=-1;
    
    for (int i=0; i<3; i++){
        // cycle through consistant order
		int current=order[(startPlayer+i)%3];
        
        Player* p;
        if (current==0) p=&p1;
        else if (current==1) p=&p2;
        else p=&p3;
        
        Card played;
        
        if (current==0){
            played=playUser(*p, lastValue);
        } else {
            played=playBot(*p, lastValue);
        }
        
        pool[poolSize++]={current, played};

		// print card played during non final rounds
        if (!finalRound){
            cout<<"\nPlayer "<<current+1<<" played: "<<played.face<<" of "<<played.suit<<endl;
            printCard(played);
        }

		// switches round winner with every higher card value 
        lastValue=played.value;
        
        if(played.value>=highest){
            highest=played.value;
            winner=current;
        }
    }

	// print round winner during non final rounds
    if (!finalRound){
        cout<<"\nPlayer "<<winner+1<<" won this round.\n";
    }

    return winner;
}

// determine winner
int resolveFinal (Player &p1, Player &p2, Player &p3, int startPlayer) {
    Card cards[3]={p1.hand[0], p2.hand[0], p3.hand[0]};
    
    int order[3]={
        startPlayer,
        (startPlayer+1)%3,
        (startPlayer+2)%3
    };
    
    int winner=order[0];
    int lowest=cards[winner].value;
    
    for(int i=0; i<3; i++){
        int current=order[i];
        
        if(cards[current].value<lowest){
            lowest=cards[current].value;
            winner=current;
        }else if(cards[current].value==lowest){
            winner=current;
        }
    }
    
    return winner;
}

Card playUser(Player &p, int lastValue) {
    // remove selected card from hand
	if (p.handSize==1){
            Card chosen=p.hand[0];
            removeCard(p, 0);
            return chosen;
    }
        
    // print hand 
    cout<<"\nYour hand:\n\n";
    for(int i=0; i<p.handSize; i++){
        cout<<i+1<<":"<<p.hand[i].face<<" of "<<p.hand[i].suit<<endl;
    }
    
    int choice;

	// choose valid card
    while(true){
        cout<<"\nChoose a card: ";
        cin>>choice;
        
        if (error()) continue;
        	
        if(choice<1||choice>p.handSize){
                cout<<"Invalid input. Please try again.";
                continue;
        }
        
        int idx=choice-1;
        
        bool hasLegal=false;
        for(int i=0; i<p.handSize; i++){
            if (p.hand[i].value>=lastValue){
                hasLegal=true;
                break;
            }
        }
        
        if (hasLegal&&p.hand[idx].value<lastValue){
            cout<<"You must play >= "<<lastValue<<" or your lowest card.\n";
            continue;
        }
        
        Card chosen=p.hand[idx];
        removeCard(p, idx);
        return chosen;
    }
}

Card playBot (Player &p, int lastValue) {
    // selects next playable card 
	int idx=findLegal(p, lastValue);
    
    if(idx==-1){
        idx=findLowest(p);
    }

	// remove selected card from hand 
    Card chosen = p.hand[idx];
    removeCard(p, idx);
    
    return chosen;
}


